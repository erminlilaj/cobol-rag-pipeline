COBOL_RAG_CONFIG=config/default.yaml
COBOL_RAG_CHROMA_DIR=.chroma
COBOL_RAG_INBOX_DIR=data/inbox
COBOL_RAG_COLLECTION=cobol-dev

COBOL_RAG_LLM_PROVIDER=ollama
COBOL_RAG_LLM_MODEL=granite-code:8b
COBOL_RAG_LLM_BASE_URL=http://localhost:11434
COBOL_RAG_LLM_CONTEXT_WINDOW=4096
COBOL_RAG_LLM_REQUEST_TIMEOUT=300
COBOL_RAG_LLM_TEMPERATURE=0.1

COBOL_RAG_EMBEDDING_PROVIDER=ollama
COBOL_RAG_EMBEDDING_MODEL=mxbai-embed-large:latest
COBOL_RAG_EMBEDDING_BASE_URL=http://localhost:11434

COBOL_RAG_TOP_K=6
COBOL_RAG_REQUIRE_CITATIONS=true
COBOL_RAG_SHOW_SOURCES=true
