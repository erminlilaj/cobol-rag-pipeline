{
  "schema_version": 1,
  "suite": "pdcbvc_gold",
  "program": "PDCBVC",
  "description": "Gold evaluation set for the PDCBVC COBOL RAG assistant. The suite separates deterministic final_scripts questions from RAG/LLM questions that require a live index and Ollama.",
  "defaults": {
    "requirements": ["final_scripts"],
    "case_sensitive": false,
    "top_k": null
  },
  "cases": [
    {
      "id": "assistant.greeting",
      "category": "assistant",
      "question": "hi",
      "requirements": [],
      "assertions": {
        "contains_all": ["COBOL RAG assistant", "called programs", "COMMAREA"],
        "forbidden": ["configured Ollama model", "I cannot search"]
      }
    },
    {
      "id": "assistant.identity",
      "category": "assistant",
      "question": "who are you",
      "requirements": [],
      "assertions": {
        "contains_all": ["local COBOL RAG assistant", "indexed analysis artifacts", "control flow"],
        "forbidden": ["I cannot search", "not responding"]
      }
    },
    {
      "id": "metadata.line_count",
      "category": "metadata",
      "question": "How many code lines is PDCBVC?",
      "assertions": {
        "contains_all": ["912 total physical source lines", "392 LOC", "14 paragraphs", "65 comment lines", "15 comments", "Evidence:", "program.comments/program.comments.json"],
        "forbidden": ["not provided", "conversation history"]
      }
    },
    {
      "id": "metadata.copybook_count",
      "category": "metadata",
      "question": "How many copybooks does PDCBVC use?",
      "assertions": {
        "contains_all": ["12 COPY members", "DFHAID", "PD1FS00", "PDCBVCM", "PXCSEMAF"],
        "forbidden": ["cannot confirm", "not provided"]
      }
    },
    {
      "id": "copybooks.roles",
      "category": "copybooks",
      "question": "Which copybooks are included by PDCBVC.CBL, and what role does each one play in the program?",
      "assertions": {
        "contains_all": ["COPY members (12)", "DFHAID", "CICS AID key constants", "DFHBMSCA", "BMS map attribute", "PD1FS00 service/session", "PD1VOCI accounting-voice", "PDCBVCM", "map/BMS screen fields", "PDRTWA2", "TWA/state context", "PXCSEMAF", "PDAGGVIP"],
        "forbidden": ["customer information", "booking travel", "flight number", "vehicle rentals", "hotel room", "car rental"]
      }
    },
    {
      "id": "metadata.call_count",
      "category": "metadata",
      "question": "How many outgoing calls does PDCBVC have?",
      "assertions": {
        "contains_all": ["5 outgoing calls", "architecture.call_parameters.json"]
      }
    },
    {
      "id": "metadata.literal_count",
      "category": "metadata",
      "question": "How many forced values does PDCBVC have?",
      "assertions": {
        "contains_all": ["65 literal assignments", "dataflow.literal_assignments.json"]
      }
    },
    {
      "id": "calls.all_parameters",
      "category": "calls",
      "question": "Which programs does PDCBVC call and with which parameters?",
      "assertions": {
        "contains_all": ["PD1VOCI", "WPD1VOCI", "PD1FS00", "WPD1FS00", "PXRSEMAF", "PXCSEMAF-AREA", "PD0UTI01", "WPDRUTI01", "PDPRED"],
        "forbidden": ["PD0UTI02", "PD0UTI03", "PD0UTI04", "PD0UTI09"]
      }
    },
    {
      "id": "calls.pd1fs00_parameters",
      "category": "calls",
      "question": "Which parameters are passed to PD1FS00 in PDCBVC?",
      "assertions": {
        "contains_all": ["PD1FS00", "COMMAREA=WPD1FS00", "LENGTH=PD1FS00-LUNGH", "PD1FS00-FUNZIONE"],
        "forbidden": ["WPD1VOCI"]
      }
    },
    {
      "id": "calls.pd1voci_preparation",
      "category": "calls",
      "question": "In PDCBVC.CBL, how are the parameters for the external program PD1VOCI prepared, and how do TWCOB-VARCONT-NUMFUNZ and TWCOB-FUNZIONE influence PD1VOCI-FUNZIONE, PD1VOCI-TIPO-ESTRA, and PD1VOCI-TIPO-VOCE?",
      "assertions": {
        "contains_all": ["INIZ-PARAM", "only executes the CICS LINK", "PD1VOCI-FUNZIONE", "PD1VOCI-TIPO-ESTRA", "PD1VOCI-TIPO-VOCE", "TWCOB-VARCONT-NUMFUNZ", "TWCOB-FUNZIONE", "TWCOB-VARCONT-ANNO", "TWCOB-VARCONT-MESE"],
        "forbidden": ["prepares `PD1VOCI` in `LINK-PD1VOCI`", "TWCOB-FUNZIONE controls the behavior ofPD1VOCI-LIQUID1-ANNO", "simply return", "calling program and the data being processed"]
      }
    },
    {
      "id": "control.phase_dispatch",
      "category": "control_flow",
      "question": "In PDCBVC.CBL, how does the program decide whether to execute BROWSE-FASE1 or BROWSE-FASE2, and what happens if TWCOB-FASE contains an unexpected value?",
      "assertions": {
        "contains_all": ["TWCOB-FASE = '1'", "BROWSE-FASE1", "TWCOB-FASE = '2'", "BROWSE-FASE2", "ABEND00"],
        "forbidden": ["ELSE clause and execute BROWSE-FASE2"]
      }
    },
    {
      "id": "control.phase_dispatch_variant",
      "category": "control_flow",
      "question": "How does PDCBVC decide whether to start from BROWSE-FASE1 or BROWSE-FASE2, and which TWA field controls this decision?",
      "assertions": {
        "contains_all": ["TWCOB-FASE", "TWCOB-FASE = '1'", "BROWSE-FASE1", "TWCOB-FASE = '2'", "BROWSE-FASE2", "ABEND00"],
        "forbidden": ["set to 2 in the BROWSE-FASE1 paragraph"]
      }
    },
    {
      "id": "control.ip_function_restriction",
      "category": "control_flow",
      "question": "What happens when TWCOB-FUNZIONE is one of I, A, C, D, or P and TWCOB-ID-SISTEMA = 'IP'?",
      "assertions": {
        "contains_all": ["READ-TAB-SEMAF", "PXCSEMAF-STATUS = 1", "TWCOB-AREA-MSG", "XCTL-LIV4", "PXCSEMAF-OUTCOME", "ABEND00"],
        "forbidden": ["username and password", "book a flight", "hotel room", "car rental", "travel tip"]
      }
    },
    {
      "id": "control.browse_fase1_sequence",
      "category": "control_flow",
      "question": "In PDCBVC.CBL, explain the full sequence of operations performed during BROWSE-FASE1 before the map PDCBVC1 is sent to the terminal.",
      "assertions": {
        "contains_all": ["PREP-LINK-PD1FS00", "READ-TAB-SEMAF", "INIZ-PARAM", "LINK-PD1VOCI", "CALCOLA-NPAG", "PREPARA-MAP", "SEND-PDCBVC1"],
        "forbidden": ["EXEC CICS ADDRESS TWA", "updating database records and generating reports"]
      }
    },
    {
      "id": "control.browse_fase2_enter",
      "category": "control_flow",
      "question": "Explain BROWSE-FASE2-ENTER in PDCBVC.",
      "assertions": {
        "contains_all": ["BROWSE-FASE2-ENTER", "PREP-LINK-PD1FS00", "BROWSE-FASE2-SEL", "INIZ-PARAM", "LINK-PD1VOCI", "CALCOLA-NPAG"]
      }
    },
    {
      "id": "control.xctl_liv4",
      "category": "control_flow",
      "question": "Explain XCTL-LIV4 in PDCBVC.",
      "assertions": {
        "contains_all": ["XCTL-LIV4", "RESET-TWA", "XCTL-MAIN", "TWCOB-FASE", "TWCOB-FUNZIONE", "TWCOB-NOME-PGM"],
        "contains_any": [["PROG-LIV4", "PDPRED"]]
      }
    },
    {
      "id": "control.pagination",
      "category": "control_flow",
      "question": "In PDCBVC.CBL, how is pagination calculated and maintained across user interactions, especially when the user presses ENTER, PF7, or PF8?",
      "assertions": {
        "contains_all": ["WCTPAG", "TWCOB-VARCONT-NPAGINA", "BROWSE-FASE2-ENTER", "BROWSE-FASE2-PF7", "BROWSE-FASE2-PF8"],
        "forbidden": ["TWCOB-VARCONT-NUMFUNZ and TWCOB-FUNZIONE variables to control pagination"]
      }
    },
    {
      "id": "control.page_total_calculation",
      "category": "control_flow",
      "question": "How does PDCBVC calculate the total number of pages for the browse result?",
      "assertions": {
        "contains_all": ["CALCOLA-NPAG", "PD1VOCI-TABVOX-NUMERO", "MAX-RIGHE", "NPAGT", "RESTO", "RESTO > 0", "does not use `TWCOB-VARCONT-NUMFUNZ`"],
        "forbidden": ["TWCOB-VARCONT-NUMFUNZ + 2", "multiplied by 5", "(TWCOB-VARCONT-NUMFUNZ + 2) * 5"]
      }
    },
    {
      "id": "control.row_selection",
      "category": "control_flow",
      "question": "In PDCBVC.CBL, when the user selects a row from the browse screen, how does the program validate the selected progressivo and move the selected accounting voice into the TWA before transferring control to the next program?",
      "assertions": {
        "contains_all": ["SCELTAI", "WPROGR", "BROWSE-FASE2-SEL-20", "TWCOB-VARCONT-PROGVOCE"],
        "forbidden": ["TWCOB-VARCONT-NUMFUNZ is greater than 0"]
      }
    },
    {
      "id": "control.prep_riga_row_build",
      "category": "control_flow",
      "question": "In PDCBVC.CBL, how does the program build each displayed row in PREP-RIGA, including voice code, description, start date, end date, installment amount, and record progressivo?",
      "assertions": {
        "contains_all": ["PREP-RIGA", "RIGA-MAPPA", "PD1VOCI-TABVOX-CODVOX", "PD1VOCI-TABVOX-DESCRIZ", "PD1VOCI-TABVOX-INIZ", "DATA-IMPIANTO", "PD1VOCI-TABVOX-FINE", "DATA-CESSAZIONE", "PDRUTI01-F05-IMPOX11", "IMPORTO-RATA", "PD1VOCI-TABVOX-PROGVOX", "WPROGREC", "MRIGAO"],
        "forbidden": ["SCELTAI is not equal to", "go to BROWSE-FASE2-SEL"]
      }
    },
    {
      "id": "control.pf_key_comparison",
      "category": "control_flow",
      "question": "In PDCBVC.CBL, compare the control-flow behavior of function keys PF1, PF2, PF3, PF4, and PF9. Which target programs are selected, and what common TWA reset logic is applied?",
      "assertions": {
        "contains_all": ["DFHPF1", "XCTL-LIV1", "DFHPF2", "XCTL-LIV2", "DFHPF3", "XCTL-LIV3", "DFHPF4", "XCTL-LIV4", "DFHPF9", "XCTL-LIV0", "RESET-TWA", "PDPRED"],
        "forbidden": ["PD0UTI02", "PD0UTI03", "PD0UTI04", "PD0UTI09"]
      }
    },
    {
      "id": "control.pf8_key",
      "category": "control_flow",
      "question": "What happens when the user presses PF8 in PDCBVC?",
      "assertions": {
        "contains_all": ["DFHPF8", "BROWSE-FASE2-PF8"],
        "contains_any": [["BROWSE-FASE2-ENTER", "WCTPAG"]]
      }
    },
    {
      "id": "control.semaphore_flow",
      "category": "control_flow",
      "question": "In PDCBVC.CBL, under what exact conditions does the program read the semaphore PDAGGVIP, and what control-flow path is taken when the semaphore status is closed?",
      "assertions": {
        "contains_all": ["READ-TAB-SEMAF", "PDAGGVIP", "PXCSEMAF-STATUS = 1", "XCTL-LIV4", "PXRSEMAF"],
        "forbidden": ["PD1VOCI-TABVOX-NUMERO = 0 AND TWCOB-XCTL-PGM = 'PDCGVC'"]
      }
    },
    {
      "id": "control.error_paths",
      "category": "control_flow",
      "question": "In PDCBVC.CBL, identify all paths that lead to an error message or abnormal termination, including invalid function keys, missing records, invalid selection, failed service calls, SQL errors, and semaphore restrictions.",
      "assertions": {
        "contains_all": ["ABEND00", "BROWSE-FASE2-TASTOER", "BROWSE-FASE2-NOTFND", "restriction / early-transfer paths (not ABEND00)", "supporting message/cursor field writes", "SQLERROR", "PXCSEMAF-STATUS", "PD1VOCI-RETURN", "PDRUTI01-RETURN"],
        "forbidden": ["all paths jump to ABEND00", "BrownSE"]
      }
    },
    {
      "id": "control.ui_navigation",
      "category": "ui_navigation",
      "question": "What is PDCBVC UI navigation?",
      "assertions": {
        "contains_all": ["9 item", "DFHENTER", "DFHPF1", "DFHPF7", "DFHPF8", "BROWSE-FASE2-TASTOER"]
      }
    },
    {
      "id": "dataflow.wctpag",
      "category": "dataflow",
      "question": "Where is WCTPAG set and used?",
      "assertions": {
        "contains_all": ["WCTPAG", "writes", "reads", "BROWSE-FASE2-PF8", "MUOVI-DATI", "controls flow: yes"]
      }
    },
    {
      "id": "dataflow.npagina",
      "category": "dataflow",
      "question": "Where is TWCOB-VARCONT-NPAGINA set and used?",
      "assertions": {
        "contains_all": ["TWCOB-VARCONT-NPAGINA", "origin: COMMAREA", "BROWSE-FASE1", "BROWSE-FASE2-VISUAL", "MUOVI-DATI"]
      }
    },
    {
      "id": "dataflow.pdrtwa2_to_pd1voci",
      "category": "dataflow",
      "question": "Which fields from PDRTWA2 are copied into the PD1VOCI copybook before the CICS LINK?",
      "assertions": {
        "contains_all": ["PDRTWA2", "TWCOB-VARCONT-VOCE-LIV4", "PD1VOCI-COD-VOCE", "TWCOB-TIPO-DIP", "PD1VOCI-CODDIP-TIPO", "TWCOB-FUNZIONE", "PD1VOCI-TIPO-VARIAZ", "TWCOB-VARCONT-ANNO", "PD1VOCI-LIQUID1"],
        "forbidden": ["prepared by the PDCBVC program in the LINK-PD1VOCI step"]
      }
    },
    {
      "id": "dataflow.numfunz_pd1voci_mapping",
      "category": "dataflow",
      "question": "How does TWCOB-VARCONT-NUMFUNZ change the value of PD1VOCI-FUNZIONE and PD1VOCI-TIPO-VOCE?",
      "assertions": {
        "contains_all": ["NUMFUNZ `1`", "PD1VOCI-FUNZIONE = '11'", "NUMFUNZ `6`", "PD1VOCI-FUNZIONE = '12'", "NUMFUNZ `2`", "PD1VOCI-TIPO-VOCE = '1'", "NUMFUNZ `5`", "PD1VOCI-TIPO-VOCE = '4'"],
        "forbidden": ["NUMFUNZ is equal to '1', it sets PD1VOCI-FUNZIONE to '11' and PD1VOCI-TIPO-VOCE to '1'", "NUMFUNZ is equal to '6', it sets PD1VOCI-FUNZIONE to '12' and PD1VOCI-TIPO-VOCE to '3'"]
      }
    },
    {
      "id": "dataflow.pd1fs00_session",
      "category": "dataflow",
      "question": "When does PDCBVC call PD1FS00, and what information does it obtain from the PD1FS00 copybook?",
      "assertions": {
        "contains_all": ["PREP-LINK-PD1FS00", "LINK-PD1FS00", "PD1FS00-FUNZIONE", "PD1FS00-SESS-SISTEMA", "COMMAREA=WPD1FS00", "PD1FS00-SESS-ANNO", "PD1FS00-SESS-MESE", "PD1FS00-SESS-TMENS", "PD1FS00-SESS-FLAG"],
        "forbidden": ["TWCOB-VARCONT-NUMFUNZ and TWCOB-FUNZIONE to determine which fields to move into PD1FS00"]
      }
    },
    {
      "id": "dataflow.session_status_display",
      "category": "dataflow",
      "question": "How does PDCBVC display the session status on the map, and which values of PD1FS00-SESS-FLAG correspond to Aperta, Chiusa, and Liquidata?",
      "assertions": {
        "contains_all": ["PD1FS00-SESS-FLAG = '1'", "Aperta", "PD1FS00-SESS-FLAG = '2'", "Chiusa", "PD1FS00-SESS-FLAG = '3'", "Liquidata", "MDSESSO", "MSESSIO"],
        "forbidden": ["does not provide any information", "additional analysis or testing"]
      }
    },
    {
      "id": "dataflow.scelta_map_field",
      "category": "dataflow",
      "question": "I have a problem with SCELTAI on the map, what feeds it?",
      "assertions": {
        "contains_all": ["SCELTAI", "COPY:PDCBVCM", "BROWSE-FASE2-ENTER", "BROWSE-FASE2-SEL-10", "controls flow: yes", "screen_field_lineage", "dataflow.variable/dataflow.variable.SCELTAI.json", "SCELTAL", "WPROGR"],
        "forbidden": ["PD1FS00"]
      }
    },
    {
      "id": "dataflow.forced_values",
      "category": "dataflow",
      "question": "Is there any forced value in PDCBVC?",
      "assertions": {
        "contains_all": ["65 matching item", "TWCOB-FASE = 2", "PD1FS00-FUNZIONE = 03", "PD1VOCI-FUNZIONE = 11", "M1MSGL = -1"],
        "forbidden": ["not provided"]
      }
    },
    {
      "id": "copybooks.unused_heuristic",
      "category": "copybooks",
      "question": "How many unused copybooks?",
      "assertions": {
        "contains_all": ["COPY usage heuristic", "Need review / possibly unused by this heuristic (4)", "DFHBMSCA", "PDCBVCM", "PDRTIP01", "PDRVC", "Evidence:", "architecture.unused_copybooks/architecture.unused_copybooks.json", "dataflow.used_variables/dataflow.used_variables.json"],
        "forbidden": ["cannot confirm unused"]
      }
    },
    {
      "id": "dead_code.commented_and_copy",
      "category": "dead_code",
      "question": "Is there any unused code/copy in this PDCBVC?",
      "assertions": {
        "contains_all": ["Commented-out code/data found", "15 item", "line 433", "program.comments/program.comments.json", "architecture.unused_copybooks", "DFHBMSCA", "PDRVC", "Proven unused COPY members: none"],
        "forbidden": ["No, there is no dead code"]
      }
    },
    {
      "id": "dead_code.cfg_reachability",
      "category": "dead_code",
      "question": "Is there unreachable code in PDCBVC?",
      "assertions": {
        "contains_all": ["quality.dead_code", "commented-out code/data: 15", "0 unreachable", "CFG nodes", "not a runtime execution proof"],
        "forbidden": ["No, there is no dead code"]
      }
    },
    {
      "id": "db2.sql_evidence",
      "category": "db2_sql",
      "question": "Which DB2 tables and SQL includes does PDCBVC use?",
      "assertions": {
        "contains_all": ["DB2 table DUAL", "SQL includes", "PDPSQLER", "PDWSQLER", "SQLCA"]
      }
    },
    {
      "id": "datasets.produced_missing",
      "category": "datasets",
      "question": "Which datasets does PDCBVC produce?",
      "assertions": {
        "contains_all": ["jcl.file_io", "no JCL dataset/file-I/O linkage", "PDCBVC", "Produced datasets are not evidenced", "Known JCL job(s) in the artifact set: none", "Evidence:"],
        "forbidden": ["SYSOUT", "produces dataset"]
      }
    },
    {
      "id": "datasets.batch_program_outputs",
      "category": "datasets",
      "question": "Which datasets does PDHM730C produce?",
      "expected": "known_gap",
      "assertions": {
        "contains_all": ["PDHM730C JCL file-I/O evidence", "PDCAFIN2", "SKINPUT", "TEPDET.BVARIAZ.CAF", "FOUTPUT", "TEPDET.BVOCI.CAF", "SYSOUT outputs", "jcl/_batch_input_check/PDCAFIN2/jcl.steps.PDHM730C.json", "line 84"]
      }
    },
    {
      "id": "business.rules",
      "category": "business_rules",
      "question": "What business rules are in PDCBVC?",
      "assertions": {
        "contains_all": ["32 rule artifact", "BR-001", "TWCOB-FASE", "BR-004", "PXCSEMAF-STATUS"]
      }
    },
    {
      "id": "entity.unknown_variable",
      "category": "entity_validation",
      "question": "What does FUNZA do?",
      "assertions": {
        "contains_all": ["I do not have indexed dataflow evidence for variable `FUNZA`", "Closest indexed variable: `FUNZ`", "will not infer"],
        "forbidden": ["hypothetical", "common practices", "likely that FUNZA"]
      }
    },
    {
      "id": "entity.known_variable",
      "category": "entity_validation",
      "question": "What does FUNZ do?",
      "assertions": {
        "contains_all": ["PDCBVC variable `FUNZ`", "origin: WORKING-STORAGE", "line 705", "line 707"],
        "forbidden": ["hypothetical", "common practices"]
      }
    },
    {
      "id": "entity.unknown_program",
      "category": "entity_validation",
      "question": "What is file PB3210N about?",
      "assertions": {
        "contains_all": ["I do not have indexed analysis for `PB3210N`", "Indexed program(s) currently available: PDCBVC"],
        "forbidden": ["controls the flow of data", "can be inferred"]
      }
    },
    {
      "id": "entity.call_target_not_indexed_program",
      "category": "entity_validation",
      "question": "What does PD1VOCI do?",
      "assertions": {
        "contains_all": ["not indexed as a standalone program", "call target", "COMMAREA=WPD1VOCI", "COPY member"],
        "forbidden": ["Generate and index that program's analysis artifacts first, then ask again."]
      }
    },
    {
      "id": "rag.program_purpose",
      "category": "rag_llm",
      "question": "What is the purpose of program PDCBVC?",
      "requirements": ["rag_index", "ollama"],
      "assertions": {
        "contains_all": ["PDCBVC"],
        "contains_any": [["browse", "CICS", "program", "accounting", "voice"]]
      }
    },
    {
      "id": "fusion.calls.cross_source_parameters",
      "category": "fusion",
      "question": "Which programs does PDCBVC call and with which parameters?",
      "requirements": ["rag_index"],
      "required_chunk_types": ["architecture.call_parameters", "cobol_rekt.call_contract"],
      "assertions": {
        "contains_all": ["PD1VOCI", "WPD1VOCI", "LENGTH", "Sources used"],
        "forbidden": ["PDCBVCM is an external program"]
      }
    },
    {
      "id": "fusion.ui_navigation_pf_keys",
      "category": "fusion",
      "question": "Which PF keys does PDCBVC handle?",
      "requirements": ["rag_index"],
      "required_chunk_types": ["ui.cics.navigation"],
      "assertions": {
        "contains_all": ["DFHPF1", "DFHPF7", "DFHPF8", "Sources used"],
        "forbidden": ["PD0UTI02", "PD0UTI03"]
      }
    },
    {
      "id": "fusion.twcob_fase_dataflow",
      "category": "fusion",
      "question": "Where is TWCOB-FASE read or written?",
      "requirements": ["rag_index"],
      "required_chunk_types": ["dataflow.variable"],
      "assertions": {
        "contains_all": ["TWCOB-FASE", "line", "Sources used"],
        "forbidden": ["not present in the indexed evidence"]
      }
    },
    {
      "id": "fusion.sql_includes",
      "category": "fusion",
      "question": "Which SQL includes are used by PDCBVC?",
      "requirements": ["rag_index"],
      "required_chunk_types": ["architecture.sqlinclude"],
      "assertions": {
        "contains_all": ["SQLCA", "PDPSQLER", "PDWSQLER", "Sources used"]
      }
    },
    {
      "id": "fusion.copybook_conflict_caveat",
      "category": "fusion",
      "question": "Can I trust the PDCBVC copybook count if MAPA and cobol-rekt disagree?",
      "requirements": ["rag_index"],
      "required_chunk_types": ["integration.conflicts"],
      "assertions": {
        "contains_all": ["conflict", "source", "Sources used"],
        "forbidden": ["single compiler-level truth"]
      }
    }
  ]
}
